{
  "version": 2,
  "name": "ad-intelligence",
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "env": {
    "META_TOKEN": "@meta_token",
    "OPENROUTER_KEY": "@openrouter_key"
  }
}
